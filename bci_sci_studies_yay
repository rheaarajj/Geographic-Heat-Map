library(tidyverse)
library(plotly)

df <- read_csv("bci_sci_studies_woo - Sheet1.csv")

country_counts <- df %>%
    group_by(Country) %>%
    summarise(Study_Count = n())

fig <- plot_ly(
    data = country_counts,
    type = "choropleth",
    locations = ~Country,
    locationmode = "country names",
    z = ~Study_Count,
    zmin = 0,
    zmax = max(country_counts$Study_Count),
    colorscale = "Blues",
    reversescale = TRUE,
    colorbar = list(title = "Study Count")
) %>%
    layout(
        title = "Global Distribution of BCI Spinal Cord Injury Studies"
    )

fig
