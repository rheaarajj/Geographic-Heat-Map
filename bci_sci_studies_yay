library(tidyverse)
library(plotly)

df <- read_csv("new_bci_sci_studies_woo - Sheet1.csv")

country_counts <- df %>%
    group_by(Countries) %>%
    summarise(Study_Count = `Study count`)

fig <- plot_ly(
    data = country_counts,
    type = "choropleth",
    locations = ~Countries,
    locationmode = "country names",
    z = ~Study_Count,
    zmin = 0,
    zmax = max(country_counts$Study_Count),
    colorscale = "Blues",
    reversescale = TRUE,
    colorbar = list(title = "Study Count", tickfont = list(family = "Helvetica"))
) %>%
    layout(
        title = list(
            text = "BCI Studies Across Neurological and Motor Impairment Populations",
            font = list(family = "Helvetica")
        ),
        font = list(family = "Helvetica")
    )

fig
